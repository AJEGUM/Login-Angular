# IMAGEN BASE
# Node.js 22 sobre Alpine Linux (distro minimalista ~5MB).
# porque Node.js es necesario en producción para ejecutar
FROM node:22-alpine

# Define /app como directorio de trabajo dentro del contenedor.
# Todos los comandos siguientes (COPY, RUN, CMD) se ejecutan desde aquí.
WORKDIR /app

# --- Optimización de caché de Docker ---
# Copiamos SOLO el package.json primero e instalamos dependencias.
# Docker cachea esta capa por separado del código fuente.
# Resultado: si cambias tu código pero NO el package.json,
# Docker reutiliza node_modules cacheado y se salta el npm install,
# ahorrando minutos en cada reconstrucción.
COPY package*.json ./
RUN npm install

# Ahora sí copiamos todo el código fuente (controladores, modelos,
# rutas, lógica de negocio, etc.). Va DESPUÉS del npm install
# precisamente para aprovechar la caché explicada arriba.
COPY . .

# El contenedor escucha internamente en el puerto 3000.
# El mapeo real al exterior se define en el docker-compose.yml:
#   ports:
#     - "3000:3000"  →  host:contenedor
EXPOSE 3000

# Inicia la aplicación usando la forma de array.
# Existen dos formas de escribir CMD:
#
#   Shell form:  CMD "node server.js"
#   Exec form:   CMD ["node", "server.js"]   ← esta
#
# La diferencia es crítica:
#   - Shell form: Docker lanza un shell (/bin/sh) que a su vez
#     lanza Node. El PID 1 es el shell, no Node.
#     Las señales del sistema (SIGTERM para apagar limpiamente)
#     llegan al shell y Node nunca las recibe → apagado brusco.
#
#   - Exec form: Docker lanza Node directamente como PID 1.
#     Las señales llegan directo a Node → puede cerrar conexiones
#     a la DB, terminar requests activos y apagarse limpiamente.
CMD ["node", "server.js"]