# 1. Imagen base de construcción
# Se emplea Node.js 22 sobre Alpine Linux para el proceso de compilación.
# El alias "AS build" permite referenciar los artefactos generados en etapas posteriores.
FROM node:22-alpine AS build

# 2. Directorio de trabajo
# Define la ruta interna donde se ejecutará la instalación y el build.
WORKDIR /app

# 3. Gestión de dependencias
# Se transfieren los archivos de manifiesto (package.json) para la instalación de módulos.
# Este paso precede al copiado del código fuente para optimizar el uso de la caché de Docker.
COPY package*.json ./
RUN npm install

# 4. Copiado y compilación
# Se transfiere la totalidad del código fuente y se ejecuta el script de construcción.
# El resultado se almacena en el directorio /dist de acuerdo a la configuración del framework.
COPY . .
RUN npm run build

# 1. Imagen base de producción
# Se utiliza Nginx Alpine por su alta eficiencia y bajo consumo de recursos
# al servir archivos estáticos (HTML, JS, CSS).
FROM nginx:alpine

# 2. Transferencia de artefactos
# Se extrae únicamente el contenido compilado de la etapa anterior ("--from=build").
# La ruta de origen debe validarse según la configuración de salida (outputPath) 
# de la tecnología utilizada (Angular, React, Vue, etc.).
COPY --from=build /app/dist/frontend/browser /usr/share/nginx/html

# 3. Configuración de red
# Establece el puerto 80 como el canal de comunicación del contenedor.
EXPOSE 80

# 4. Ejecución del servicio
# Inicia el servidor Nginx en primer plano (daemon off) para garantizar
# la persistencia del proceso dentro del contenedor.
CMD ["nginx", "-g", "daemon off;"]